{
  "manifest_version": 3,
  "name": "CLOE — Custom Links Opened Externally",
  "description": "Selectively open links from PWAs in your system default browser via configurable URL patterns.",
  "version": "0.1.0",
  "permissions": [
    "nativeMessaging",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
